# Server port (Render.com sets this automatically, default 10000)
PORT=3001

# Node environment
NODE_ENV=development

# Optional: Comma-separated allowed origins for CORS
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3001

# Optional: Set by Render.com automatically
# RENDER_REGION=oregon
# RENDER_SERVICE_NAME=us-region-renderer

# Optional: React app API URL (leave empty for same-origin in production)
# VITE_API_URL=https://your-service.onrender.com
